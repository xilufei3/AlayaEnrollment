# ╔══════════════════════════════════════════════════════════════╗
# ║  AlayaEnrollment 环境变量模板                                ║
# ║  复制为 .env 后按需修改；标 [必填] 的变量启动时会校验          ║
# ╚══════════════════════════════════════════════════════════════╝

# ── 前端（浏览器可见，NEXT_PUBLIC_ 前缀） ─────────────────────

# Docker 模式下，宿主机暴露的 Next.js 端口（对应 docker-compose.yml 中的 WEB_HOST_PORT）
WEB_HOST_PORT=3001

# Next.js BFF 代理的 API 路径前缀（一般不需要改）
NEXT_PUBLIC_API_URL=/api

# LangGraph assistant ID（固定值，对应后端 graph 名称）
NEXT_PUBLIC_ASSISTANT_ID=agent

# LangSmith 追踪密钥（可选，不填则不上报前端追踪）
NEXT_PUBLIC_LANGSMITH_API_KEY=

# ── 后端 API 保护 ────────────────────────────────────────────

# [必填] BFF → FastAPI 的共享密钥，所有非 /health /info /metrics 的请求都需要此 Key
# 浏览器不接触此值，由 Next.js 服务端注入。生产环境务必修改！
API_SHARED_KEY=change-me

# Next.js 服务端连接后端的内部地址（Docker 模式下自动覆盖为 http://backend:8008）
BACKEND_INTERNAL_URL=http://127.0.0.1:8008

# 流式请求（SSE）最大总时长，超时后服务端主动断开（秒）
STREAM_MAX_DURATION_SECONDS=120

# 流式请求空闲超时，超过此时间无新 token 输出则断开（秒）
STREAM_IDLE_TIMEOUT_SECONDS=30

# ── CORS 跨域 ────────────────────────────────────────────────

# 允许的跨域来源，逗号分隔（如 https://example.com,https://app.example.com）
# 空 = 禁用 CORS（BFF 架构下推荐，浏览器不直连 FastAPI）
CORS_ALLOWED_ORIGINS=

# ── Per-device 速率限制 ──────────────────────────────────────

# 单个 device_id 在滑动窗口内允许的最大请求数
DEVICE_RATE_LIMIT_MAX=30

# 滑动窗口长度（秒）。默认：30 次 / 60 秒
DEVICE_RATE_LIMIT_WINDOW=60

# ── Milvus 向量数据库 ────────────────────────────────────────

# Milvus 连接地址（Docker 模式下自动覆盖为 http://milvus:19530）
MILVUS_URI=http://localhost:19530

# 向量集合名称
MILVUS_COLLECTION=admissions_knowledge

# 向量维度（必须与 Embedding 模型输出维度一致）
EMBED_DIM=768

# 以下仅在 Milvus 开启认证或多数据库时需要
MILVUS_TOKEN=
MILVUS_DB_NAME=

# ── MinIO 对象存储（Milvus 依赖） ────────────────────────────

# Milvus Docker Compose 使用的 MinIO 凭据。生产环境务必修改！
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── Embedding / ETL 服务 ─────────────────────────────────────

# Alaya Embedding 服务地址（用于文档向量化）
AlayaData_URL=http://100.64.0.30:6000

# 可选：切换到自定义 OpenAI 兼容 Embedding 接口。
# 如果启用 Qwen/Qwen3-Embedding-8B，请同时将 EMBED_DIM 改为 4096，并重建 Milvus collection。
USE_CUSTOM_EMBEDDING=false
CUSTOM_EMBEDDING_API_BASE=http://172.18.41.222:18005
CUSTOM_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
CUSTOM_EMBEDDING_API_KEY=
CUSTOM_EMBEDDING_API_KEY_FILE=.sglang_api_key
CUSTOM_EMBEDDING_TIMEOUT=120
CUSTOM_EMBEDDING_BATCH_SIZE=32

# ── LLM 模型配置 ─────────────────────────────────────────────

# DeepSeek（可选，与 Qwen 二选一即可）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# [必填] Qwen（默认 LLM Provider，所有节点兜底使用此配置）
QWEN_API_KEY=
QWEN_BASE_URL=https://star.sustech.edu.cn/service/model/qwen/v1
QWEN_MODEL_NAME=qwen3.5-397b-a17b-fp8

# 可选：节点级覆写。不填时，各节点自动继承上面的 QWEN_* 配置。
INTENT_MODEL_API_KEY=
INTENT_MODEL_BASE_URL=
INTENT_MODEL_MODEL_NAME=
GENERATION_MODEL_API_KEY=
GENERATION_MODEL_BASE_URL=
GENERATION_MODEL_MODEL_NAME=
PLANNER_MODEL_API_KEY=
PLANNER_MODEL_BASE_URL=
PLANNER_MODEL_MODEL_NAME=
EVAL_MODEL_API_KEY=
EVAL_MODEL_BASE_URL=
EVAL_MODEL_MODEL_NAME=

# 各节点独立的超时和重试配置（秒 / 次数）
# 意图分类
INTENT_MODEL_TIMEOUT_SECONDS=8
INTENT_MODEL_MAX_RETRIES=0
# 回答生成
GENERATION_MODEL_TIMEOUT_SECONDS=25
GENERATION_MODEL_MAX_RETRIES=0
# 检索规划
PLANNER_MODEL_TIMEOUT_SECONDS=12
PLANNER_MODEL_MAX_RETRIES=0
# 充分性评估
EVAL_MODEL_TIMEOUT_SECONDS=8
EVAL_MODEL_MAX_RETRIES=0

# [必填] Jina Reranker（文档重排序）
JINA_API_KEY=
JINA_MODEL_NAME=jina-reranker-v3
# 重排序后保留的 top N 文档数
RERANK_TOP_N=5
RERANK_MODEL_TIMEOUT_SECONDS=8
RERANK_MODEL_MAX_RETRIES=0

# ── Langfuse 可观测性（可选） ─────────────────────────────────

# 设为 true 开启 LLM 调用追踪上报；false 或不填则完全不初始化 Langfuse
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── 运行时参数 ────────────────────────────────────────────────

# 运行时数据目录（checkpoint / thread_registry / 日志）
# 空 = 使用项目根目录下的 .runtime/；生产环境建议设为仓库外路径如 /var/lib/alaya-enrollment/runtime
RUNTIME_ROOT=

# 对话历史窗口：传给 LLM 的最近 k 轮对话（每轮 = 1 条用户 + 1 条助手）
HISTORY_LAST_K_TURNS=6

# 意图分类置信度阈值：低于此值归为 other（闲聊）
INTENT_CONFIDENCE_THRESHOLD=0.55

# 内存 thread 缓存：最多保留 N 个 thread 对象，超出 LRU 淘汰（数据仍在 SQLite，按需重载）
THREAD_CACHE_MAX=2000

# thread 缓存 TTL：超过此秒数未访问的 thread 从内存淘汰（秒）
THREAD_CACHE_TTL=7200

# ── 日志 ──────────────────────────────────────────────────────

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ── 微信公众号 ─────────────────────────────────────────────────

# 设为 true 启用微信公众号适配（注册 /wx 端点）
WECHAT_ENABLED=true

# 公众号后台「基本配置」→「服务器配置」中设置的 Token
WECHAT_TOKEN="a0349dsn2kdslke"

# 公众号 AppID（选填：暂用于日志标识，后续可扩展为客服消息接口认证）
WECHAT_APPID=

# 公众号 AppSecret（选填：暂用于日志标识，后续可扩展为客服消息接口认证）
WECHAT_APPSECRET=

# 微信渠道模型覆盖（选填）
# 设置后，只有 channel=wechat 的请求会优先使用该模型，不影响 Web/BFF 渠道。
WECHAT_MODEL_NAME=

# 也可按节点细分（优先级高于 WECHAT_MODEL_NAME）
# WECHAT_INTENT_MODEL_NAME=
# WECHAT_PLANNER_MODEL_NAME=
# WECHAT_EVAL_MODEL_NAME=
# WECHAT_GENERATION_MODEL_NAME=

# 微信渠道 RAG 最大重试轮次（选填）
# 例如设为 1，则微信请求最多执行 1 次重试（Web/BFF 不受影响）
WECHAT_RAG_MAX_ITERATIONS=
