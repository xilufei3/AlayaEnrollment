# Frontend / LangGraph
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_ASSISTANT_ID=agent
NEXT_PUBLIC_LANGSMITH_API_KEY=

# Backend API protection
API_SHARED_KEY=change-me
BACKEND_INTERNAL_URL=http://127.0.0.1:8008
STREAM_MAX_DURATION_SECONDS=120
STREAM_IDLE_TIMEOUT_SECONDS=30

# Milvus
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=admissions_knowledge
EMBED_DIM=768
# Optional: only needed when Milvus auth or multi-database is enabled
MILVUS_TOKEN=
MILVUS_DB_NAME=

# Alaya embedding / ETL service
AlayaData_URL=http://100.64.0.30:6000

# Model providers
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

QWEN_API_KEY=
QWEN_BASE_URL=http://star.sustech.edu.cn/service/model/qwen35/v1

JINA_API_KEY=
JINA_MODEL_NAME=jina-reranker-v3
RERANK_TOP_N=5

# Langfuse observability (optional)
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Runtime settings
RUNTIME_ROOT=
HISTORY_LAST_K_TURNS=6
INTENT_CONFIDENCE_THRESHOLD=0.55
