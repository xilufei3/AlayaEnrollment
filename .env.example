# 对话历史：提取最近 k 轮（每轮=1 用户+1 助手），默认 6 轮
HISTORY_LAST_K_TURNS=6

# 意图分类置信度阈值，低于此值时跳过检索直接生成，默认 0.55
INTENT_CONFIDENCE_THRESHOLD=0.55
